root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 4

# Markdown : les deux espaces de fin servent aux retours à la ligne.
[*.md]
trim_trailing_whitespace = false

# Lockfile généré par npm (indentation 2 espaces).
[package-lock.json]
indent_style = space
indent_size = 2
