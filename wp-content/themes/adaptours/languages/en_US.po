msgctxt "block description"
msgid "Une condition : titre court et explication. La numérotation se calcule toute seule. À utiliser dans le bloc « Recrutement »."
msgstr "A requirement: short title and explanation. The numbering is computed automatically. Use it inside the “Recruitment” block."

msgctxt "block title"
msgid "Qui sommes-nous — recrutement"
msgstr "About us — recruitment"

msgctxt "block description"
msgid "Section recrutement : présentation et adresse pour les CV à gauche, liste des conditions (à ajouter une par une) à droite."
msgstr "Recruitment section: introduction and CV address on the left, list of requirements (added one by one) on the right."

msgctxt "block title"
msgid "Texte enrichi"
msgstr "Rich text"

msgctxt "block description"
msgid "Bloc de texte éditorial : surtitre, titre (avec mot(s) en orange) et un corps libre (paragraphes, sous-titres, listes à puces)."
msgstr "Editorial text block: small heading, title (with word(s) in orange) and a free body (paragraphs, subheadings, bulleted lists)."

msgctxt "block title"
msgid "Accessibilité"
msgstr "Accessibility"

msgctxt "block description"
msgid "Section « pensé pour tous » : titre, texte d’introduction et 4 cartes d’accessibilité (icône + titre + description). Le texte et les cartes viennent de la fiche destination."
msgstr "“Designed for everyone” section: title, introduction text and 4 accessibility cards (icon + title + description). The text and cards come from the destination page."

msgctxt "block title"
msgid "Carte du voyage"
msgstr "Trip map"

msgctxt "block description"
msgid "Section « sur la carte » : titre, texte de vol, carte de la destination et bande d’infos (décalage, visa, monnaie, langue). La carte et les infos viennent de la fiche destination."
msgstr "“On the map” section: title, flight text, destination map and an info bar (time difference, visa, currency, language). The map and info come from the destination page."

msgctxt "block title"
msgid "Ce qu’il faut savoir"
msgstr "What you need to know"

msgctxt "block description"
msgid "Section « ce qu’il faut savoir » : titre, texte d’intro et cartes pratiques (visa, santé, budget…). Ajoutez autant de cartes que nécessaire."
msgstr "“What you need to know” section: title, intro text and practical cards (visa, health, budget…). Add as many cards as needed."

msgctxt "block title"
msgid "Accueil — la promesse"
msgstr "Home — the promise"

msgctxt "block description"
msgid "Section « Le voyage, pensé autour de vous » : surtitre, titre, texte de présentation et 4 atouts illustrés."
msgstr "“Travel, designed around you” section: small heading, title, introductory text and 4 illustrated strengths."

msgctxt "block title"
msgid "Membre de l'équipe"
msgstr "Team member"

msgctxt "block description"
msgid "Une personne de l'équipe : photo, nom, poste et petite phrase. À utiliser dans le bloc « L'équipe »."
msgstr "A team member: photo, name, position and short sentence. Use it inside the “Team” block."

msgctxt "block title"
msgid "Qui sommes-nous — l'équipe"
msgstr "About us — the team"

msgctxt "block description"
msgid "Section équipe : surtitre, titre, description et une grille de personnes (à ajouter une par une), avec une bande « on recrute ? » en bas."
msgstr "Team section: small heading, title, description and a grid of people (added one by one), with a “we’re hiring?” bar at the bottom."

msgctxt "block title"
msgid "Accueil — l'équipe"
msgstr "Home — the team"

msgctxt "block description"
msgid "Section de présentation de l'équipe : surtitre, titre, deux paragraphes, bouton et un visuel."
msgstr "Team introduction section: small heading, title, two paragraphs, button and a visual."

