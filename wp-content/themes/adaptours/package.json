{
	"name": "adaptours-theme",
	"version": "0.1.0",
	"description": "Thème WordPress custom Adaptours — build des assets front.",
	"private": true,
	"license": "GPL-2.0-or-later",
	"scripts": {
		"build:css": "sass assets/src/scss/main.scss assets/build/main.css --load-path=assets/src/scss --style=compressed --no-source-map",
		"watch:css": "sass --watch assets/src/scss/main.scss:assets/build/main.css --load-path=assets/src/scss",
		"build:blocks": "wp-scripts build --webpack-src-dir=blocks --output-path=assets/build/blocks",
		"start:blocks": "wp-scripts start --webpack-src-dir=blocks --output-path=assets/build/blocks",
		"build": "npm run build:css && npm run build:blocks",
		"dev": "concurrently -k -n css,blocks,sync -c blue,magenta,green \"npm:watch:css\" \"npm:start:blocks\" \"npm:sync\"",
		"sync": "browser-sync start --config bs-config.js",
		"lint:css": "wp-scripts lint-style \"assets/src/scss/**/*.scss\" \"blocks/**/*.scss\"",
		"new-block": "node scripts/new-block.js"
	},
	"devDependencies": {
		"@wordpress/scripts": "^30.0.0",
		"browser-sync": "^3.0.4",
		"concurrently": "^10.0.3",
		"sass": "^1.80.0"
	},
	"browserslist": [
		"> 1%",
		"last 2 versions",
		"not dead"
	],
	"engines": {
		"node": ">=20"
	}
}
