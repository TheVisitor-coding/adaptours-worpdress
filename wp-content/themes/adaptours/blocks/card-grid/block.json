{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "adaptours/card-grid",
	"title": "Grille de cartes",
	"category": "adaptours",
	"icon": "screenoptions",
	"description": "En-tête (surtitre, titre) et une grille de cartes illustrées (image, titre, texte, lien facultatif). Ajoutez autant de cartes que nécessaire.",
	"textdomain": "adaptours",
	"supports": {
		"html": false,
		"anchor": true
	},
	"attributes": {
		"eyebrow": { "type": "string", "default": "" },
		"title_part_1": { "type": "string", "default": "Titre de la" },
		"title_part_2": { "type": "string", "default": "section" },
		"columns": { "type": "number", "default": 3 }
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
