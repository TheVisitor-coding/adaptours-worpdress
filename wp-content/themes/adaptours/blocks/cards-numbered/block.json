{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "adaptours/cards-numbered",
	"title": "Cartes numérotées",
	"category": "adaptours",
	"icon": "editor-ol",
	"description": "En-tête (surtitre, titre, texte) et une série de cartes numérotées automatiquement. Ajoutez autant de cartes que nécessaire.",
	"textdomain": "adaptours",
	"supports": {
		"html": false,
		"anchor": true
	},
	"attributes": {
		"eyebrow": { "type": "string", "default": "" },
		"title_part_1": { "type": "string", "default": "Titre de la" },
		"title_part_2": { "type": "string", "default": "section" },
		"description": { "type": "string", "default": "" }
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
