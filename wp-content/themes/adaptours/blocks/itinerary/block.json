{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "adaptours/itinerary",
	"title": "Le programme",
	"category": "adaptours",
	"icon": "list-view",
	"description": "Section « le programme » : titre, texte d’intro et liste d’étapes (jour par jour). Ajoutez une étape par jour.",
	"textdomain": "adaptours",
	"supports": {
		"align": ["full"],
		"html": false,
		"anchor": true
	},
	"attributes": {
		"eyebrow": { "type": "string", "default": "Itinéraire" },
		"title": { "type": "string", "default": "Le Programme" },
		"title_accent": { "type": "string", "default": "" },
		"description": { "type": "string", "default": "" }
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
