{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "adaptours/section-map",
	"title": "Carte du voyage",
	"category": "adaptours",
	"icon": "location-alt",
	"description": "Section « sur la carte » : titre, texte de vol, carte de la destination et bande d’infos (décalage, visa, monnaie, langue). La carte et les infos viennent de la fiche destination.",
	"textdomain": "adaptours",
	"supports": {
		"align": ["full"],
		"html": false,
		"anchor": true
	},
	"attributes": {
		"eyebrow": { "type": "string", "default": "Sur la carte" },
		"title": { "type": "string", "default": "De Paris à" },
		"title_accent": { "type": "string", "default": "" },
		"description": { "type": "string", "default": "" },
		"distance_label": { "type": "string", "default": "" }
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
