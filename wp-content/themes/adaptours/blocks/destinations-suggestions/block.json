{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "adaptours/destinations-suggestions",
	"title": "Destinations suggérées",
	"category": "adaptours",
	"icon": "grid-view",
	"description": "Section « vous aimerez aussi » : titre, texte d’intro, bouton et jusqu’à 4 destinations. Les destinations se choisissent dans la fiche.",
	"textdomain": "adaptours",
	"supports": {
		"align": ["full"],
		"html": false,
		"anchor": true
	},
	"attributes": {
		"eyebrow": { "type": "string", "default": "Pour aller plus loin" },
		"title": { "type": "string", "default": "Vous aimerez aussi" },
		"title_accent": { "type": "string", "default": "ces îles-là." },
		"description": { "type": "string", "default": "" },
		"cta_label": { "type": "string", "default": "Toutes les destinations" },
		"cta_url": { "type": "string", "default": "" }
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
