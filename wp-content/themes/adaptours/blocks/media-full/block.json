{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "adaptours/media-full",
	"title": "Image en grand",
	"category": "adaptours",
	"icon": "format-image",
	"description": "Une grande image, pleine largeur ou cadrée, avec une légende facultative.",
	"textdomain": "adaptours",
	"supports": {
		"html": false,
		"anchor": true
	},
	"attributes": {
		"image_id": { "type": "integer", "default": 0 },
		"image_url": { "type": "string", "default": "" },
		"image_alt": { "type": "string", "default": "" },
		"caption": { "type": "string", "default": "" },
		"width": { "type": "string", "default": "full-bleed" }
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
