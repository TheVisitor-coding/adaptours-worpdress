{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "adaptours/itinerary-step",
	"title": "Étape du programme",
	"category": "adaptours",
	"icon": "calendar-alt",
	"description": "Une étape (un jour) du programme : titre, description et image. À utiliser dans le bloc « Le programme ».",
	"textdomain": "adaptours",
	"parent": ["adaptours/itinerary"],
	"supports": {
		"html": false,
		"reusable": false
	},
	"attributes": {
		"title": { "type": "string", "default": "" },
		"title_accent": { "type": "string", "default": "" },
		"description": { "type": "string", "default": "" },
		"thumbnail_id": { "type": "number", "default": 0 }
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js"
}
