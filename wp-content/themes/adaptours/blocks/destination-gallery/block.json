{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "adaptours/destination-gallery",
	"title": "Galerie de la destination",
	"category": "adaptours",
	"icon": "format-gallery",
	"description": "Section « ce que vous allez voir » : titre et grille de photos (clic = agrandissement plein écran). Les photos viennent de la galerie de la fiche destination.",
	"textdomain": "adaptours",
	"supports": {
		"align": ["full"],
		"html": false,
		"anchor": true
	},
	"attributes": {
		"eyebrow": { "type": "string", "default": "La galerie" },
		"title": { "type": "string", "default": "Ce que vous allez voir." },
		"title_accent": { "type": "string", "default": "voir." },
		"tagline": { "type": "string", "default": "Nos plus belles photos" }
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
