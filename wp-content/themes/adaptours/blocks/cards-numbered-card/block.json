{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "adaptours/cards-numbered-card",
	"title": "Carte numérotée",
	"category": "adaptours",
	"icon": "index-card",
	"description": "Une carte numérotée : titre et description. À utiliser dans le bloc « Cartes numérotées ».",
	"textdomain": "adaptours",
	"parent": ["adaptours/cards-numbered"],
	"supports": {
		"html": false,
		"reusable": false
	},
	"attributes": {
		"card_title": { "type": "string", "default": "" },
		"description": { "type": "string", "default": "" }
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js"
}
