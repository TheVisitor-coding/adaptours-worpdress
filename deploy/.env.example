# Copier en .env puis renseigner les valeurs réelles (ne pas committer .env).

# Sous-domaine public de la démo. DNS : enregistrement A -> IP du VPS.
# Le certificat TLS est géré par Nginx Proxy Manager (Let's Encrypt).
WP_DOMAIN=demo-adaptours.example.fr

# Base de données (interne au réseau Docker, jamais exposée).
DB_NAME=adaptours
DB_USER=adaptours
DB_PASSWORD=change-me-strong-password

# Préfixe des tables : doit correspondre au dump importé (wp-env = wp_).
DB_PREFIX=wp_
